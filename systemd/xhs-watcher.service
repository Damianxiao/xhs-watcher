[Unit]
Description=xhs-watcher — XHS keyword scrape → LLM verdict → terminal+TG
Documentation=file:///home/damian/xhs-watcher/DESIGN.md

[Service]
Type=oneshot
WorkingDirectory=/home/damian/xhs-watcher
# Pipeline: scrape → LLM verdict → notify.
# Error policy: only `login_expired` is pushed to TG (it requires user action).
# All other errors (network / selector_missing / cf_challenge / already_running)
# are logged to /tmp/xhs-watcher.log and silently retried next hour — they're
# transient by nature and TG-spamming them adds nothing actionable.
ExecStart=/bin/bash -c '\
  /home/linuxbrew/.linuxbrew/bin/node scrape.mjs > /tmp/xhs-scrape.json 2>>/tmp/xhs-watcher.log; \
  ec=$?; \
  err=$(/home/linuxbrew/.linuxbrew/bin/node -e "let s=\"\";process.stdin.on(\"data\",b=>s+=b).on(\"end\",()=>{try{console.log(JSON.parse(s).error||\"\")}catch{console.log(\"\")}})" < /tmp/xhs-scrape.json); \
  if [ "$err" = "login_expired" ]; then \
    cat /tmp/xhs-scrape.json | /home/linuxbrew/.linuxbrew/bin/node notify.mjs --terminal --tg >>/tmp/xhs-watcher.log 2>&1; \
    exit 0; \
  fi; \
  if [ $ec -ne 0 ]; then \
    echo "[$(date -Is)] scrape exit $ec error=$err — silent (will retry next hour)" >> /tmp/xhs-watcher.log; \
    exit 0; \
  fi; \
  cat /tmp/xhs-scrape.json | /home/linuxbrew/.linuxbrew/bin/node llm-verdict.mjs > /tmp/xhs-broadcast.json 2>>/tmp/xhs-watcher.log; \
  cat /tmp/xhs-broadcast.json | /home/linuxbrew/.linuxbrew/bin/node notify.mjs --terminal --tg >>/tmp/xhs-watcher.log 2>&1; \
  cat /tmp/xhs-broadcast.json | /home/linuxbrew/.linuxbrew/bin/node notify.mjs --update-verdicts >>/tmp/xhs-watcher.log 2>&1'
StandardOutput=append:/tmp/xhs-watcher.log
StandardError=append:/tmp/xhs-watcher.log

[Install]
WantedBy=default.target
