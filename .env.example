# Copy this file to .env and fill in real values.
# NEVER commit .env — it is .gitignored.

# Telegram bot token from @BotFather
XHS_WATCHER_TG_BOT_TOKEN=your-bot-token-here

# Channel: @channel_name, or private channel numeric ID like -1001234567890
# Private chat: your user ID (number), get via getUpdates after messaging the bot
XHS_WATCHER_TG_CHAT_ID=@your_channel_or_-100xxx

# OpenAI-compatible LLM endpoint used by llm-verdict.mjs
XHS_WATCHER_LLM_BASE_URL=https://api.openai.com/v1
XHS_WATCHER_LLM_API_KEY=sk-...
XHS_WATCHER_LLM_MODEL=gpt-4o-mini
